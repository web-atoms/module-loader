{
    "compilerOptions": {
        "target": "es6",
        "ignoreDeprecations": "6.0",
        "sourceMap": true,
        "declaration": true,
        "removeComments": true,
        "outFile": "umd.js",
        "rootDir": "./umd",
        "strict": false,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "lib": [
            "es6",
            "dom"
        ]
    },
    "include": [
        "umd/src/**/*"
    ],
    "exclude": [
        "node_modules",
		"tests"
    ]
}